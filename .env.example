PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=file:./data/ecommerce.db

COMPANY_NAME="Quotify3D"
TWITTER_CREATOR="@mdeabreu"
TWITTER_SITE="https://github.com/mdeabreu/quotify3d"
SITE_NAME="Quotify3D"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# Nodemailer Email
# Leave SMTP_* blank to use Payload's console email adapter.
# Set ENABLE_MOCK_EMAIL=true to use Nodemailer's ethereal.email test account.
FROM_ADDRESS=noreply@quotify3d.com
FROM_NAME=Quotify3D
ENABLE_MOCK_EMAIL=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
